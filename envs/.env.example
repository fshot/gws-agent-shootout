# GWS Agent Shootout — Account Environment
# Copy this file to .env.gmail, .env.workspace, or .env.{client-name}
# and fill in the values. direnv loads the right one based on your .envrc.

# ── Account identity ──────────────────────────────────────────────
# The Google account email for this context
GWS_ACCOUNT=you@example.com

# The "other" account for cross-account operations (sharing, sending email)
GWS_TARGET_ACCOUNT=you@other-example.com

# Human-readable label (used in logs and artifact naming)
GWS_ACCOUNT_LABEL=personal

# ── GCP project ───────────────────────────────────────────────────
# The GCP project ID used for API access
GCP_PROJECT=my-gws-project-123456

# Path to the OAuth client credentials JSON downloaded from GCP Console
GOOGLE_CLIENT_CREDENTIALS="${HOME}/.config/gws/credentials-${GWS_ACCOUNT_LABEL}.json"

# Path to the stored OAuth token (written after first auth flow)
GOOGLE_TOKEN_PATH="${HOME}/.config/gws/token-${GWS_ACCOUNT_LABEL}.json"

# ── GWS CLI ───────────────────────────────────────────────────────
# GWS CLI picks up these automatically if set
# GWS_CREDENTIALS_FILE=${GOOGLE_CLIENT_CREDENTIALS}
# GWS_TOKEN_FILE=${GOOGLE_TOKEN_PATH}

# ── google_workspace_mcp ──────────────────────────────────────────
# The MCP server may use these (check its docs for exact var names)
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
# GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/callback

# ── Shootout-specific ─────────────────────────────────────────────
# Test calendar name (created during Phase 0)
GWS_TEST_CALENDAR="GWS Shootout"

# Isolation folder prefix
GWS_ARTIFACT_PREFIX="[GWS-${GWS_CONFIG:-X}]"
