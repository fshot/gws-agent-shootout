# GWS Agent Shootout — Account Environment
# Copy this file to {label}.env and fill in the values.
# direnv loads the right one based on your .envrc.
#
# Every variable must use `export` — direnv only tracks exported vars.

# ── Account identity ──────────────────────────────────────────────
# The Google account email for this context
export GWS_ACCOUNT=you@example.com

# The "other" account for cross-account operations (sharing, sending email)
export GWS_TARGET_ACCOUNT=you@other-example.com

# Human-readable label (used in logs and artifact naming)
export GWS_ACCOUNT_LABEL=personal

# ── GCP project ───────────────────────────────────────────────────
# The GCP project ID used for API access
export GCP_PROJECT=my-gws-project-123456

# Path to the OAuth client credentials JSON downloaded from GCP Console
export GOOGLE_CLIENT_CREDENTIALS="${HOME}/.config/gws/credentials-${GWS_ACCOUNT_LABEL}.json"

# Path to the stored OAuth token (written after first auth flow)
export GOOGLE_TOKEN_PATH="${HOME}/.config/gws/token-${GWS_ACCOUNT_LABEL}.json"

# ── GWS CLI ───────────────────────────────────────────────────────
# GWS CLI picks up these automatically if set
# export GWS_CREDENTIALS_FILE=${GOOGLE_CLIENT_CREDENTIALS}
# export GWS_TOKEN_FILE=${GOOGLE_TOKEN_PATH}

# ── google_workspace_mcp ──────────────────────────────────────────
# The MCP server may use these (check its docs for exact var names)
# export GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# export GOOGLE_CLIENT_SECRET=your-client-secret
# export GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/callback

# ── Shootout-specific ─────────────────────────────────────────────
# Test calendar name (created during Phase 0)
export GWS_TEST_CALENDAR="GWS Shootout"

# Isolation folder prefix
export GWS_ARTIFACT_PREFIX="[GWS-${GWS_CONFIG:-X}]"
